# Local machine configuration for Document Processing Pipeline V3.
# Copy this file to .env and edit values for your workstation.

# Optional. If omitted, the project root is used.
PIPELINE_BASE_DIR=

# Required. Examples:
# macOS Apple Silicon: /opt/homebrew/bin/tesseract
# macOS Intel: /usr/local/bin/tesseract
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_PATH=/opt/homebrew/bin/tesseract

# EDM integration. Keep real tokens out of git.
ENABLE_EDM_FALLBACK=false
EDM_TOKEN=
EDM_OPERATING_COMPANY=FXE
EDM_BASE_URL=
EDM_PORTAL_URL=

# OCR and scheduling.
ENABLE_INBOX_TWO_PASS=true
LONG_PASS_TIMEOUT_SECONDS=45.0
THIRD_PASS_TIMEOUT_SECONDS=195.0
GLOBAL_DOC_TIMEOUT_SECONDS=150.0
OCR_DPI_MAIN=320
OCR_DPI_STRONG=420
ROTATION_PROBE_DPI=140

# Duplicate screening.
TEXT_SIMILARITY_THRESHOLD=60
TEXT_STRONG_THRESHOLD=85
PHASH_THRESHOLD=10
PAGE_OCR_LIMIT=8
EDM_TIER1_INCOMING_PAGES=3
EDM_TIER1_EDM_PAGE_LIMIT=5
EDM_TIER2_EDM_PAGE_LIMIT=10
EDM_TEXT_LAYER_MIN_CHARS=30
EDM_OCR_WORKERS=2
EDM_OCR_PARALLEL_MIN_TASKS=4

# Batch and TIFF output.
MAX_PAGES_PER_BATCH=48
MIN_CLEAN_BATCHES_FOR_AUTO=2
TIFF_DPI=200
TIFF_COMPRESSION=tiff_lzw
TIFF_GRAYSCALE=true
TIFF_SKIP_IF_EXISTS=true
TIFF_PARALLEL_WORKERS=4

# UI auto mode.
AUTO_INTERVAL_SEC=10
AUTO_WAIT_FOR_INBOX_EMPTY=true
INBOX_EMPTY_STABLE_SECONDS=8
INBOX_EMPTY_MAX_WAIT=1800
PROCESSED_EMPTY_STABLE_SECONDS=5
PROCESSED_EMPTY_MAX_WAIT=600
AUTO_FORCE_BATCH_AGE_SECONDS=1800
