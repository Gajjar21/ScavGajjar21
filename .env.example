# =============================================================
# AWB Pipeline V3 — Environment Configuration
# =============================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every line marked  ← REQUIRED
#   3. Lines marked  ← OPTIONAL  have working defaults — change only if needed
#   4. EDM token: paste raw token into  data/token.txt  (no "Bearer" prefix)
#   5. Lines that are commented out (#) are OFF — uncomment only to override
# =============================================================


# -------------------------------------------------------------
# PATHS                                          ← REQUIRED
# -------------------------------------------------------------

# Root folder that contains  pdf_organizer/  and  data/  subdirectories.
# Use the full absolute path. No trailing slash.
#   Mac example:     /Users/yourname/Desktop/ScavGajjar21
#   Windows example: C:/Users/yourname/Desktop/ScavGajjar21
PIPELINE_BASE_DIR=                                          # ← REQUIRED

# Full path to your Tesseract binary.
#   Mac (Homebrew):  /opt/homebrew/bin/tesseract
#   Mac (Intel):     /usr/local/bin/tesseract
#   Windows:         C:/Program Files/Tesseract-OCR/tesseract.exe
#   Linux:           /usr/bin/tesseract
TESSERACT_PATH=                                             # ← REQUIRED


# -------------------------------------------------------------
# FEDEX EDM API                                  ← REQUIRED (for EDM duplicate check)
# -------------------------------------------------------------
# Ask your FedEx EDM admin for these three values.
# Token: paste the raw Bearer token into  data/token.txt  — do NOT put it here.

# Your FedEx operating company code (e.g. FDXE, FXSP, FXNL — ask FedEx)
EDM_OPERATING_COMPANY=                                      # ← REQUIRED

# FedEx EDM API base URL (provided by FedEx — production endpoint)
EDM_BASE_URL=                                               # ← REQUIRED

# FedEx EDM portal URL (used for Origin/Referer headers — provided by FedEx)
EDM_PORTAL_URL=                                             # ← REQUIRED


# -------------------------------------------------------------
# OCR / AWB MATCHING                             ← OPTIONAL
# -------------------------------------------------------------
# Defaults are tuned for production. Change only if instructed.

OCR_DPI_MAIN=320                    # DPI for first OCR pass (lower = faster)
OCR_DPI_STRONG=420                  # DPI for deep OCR pass (higher = more accurate)
ENABLE_ROTATION_LAST_RESORT=true    # Try all rotation angles as last resort
LONG_PASS_TIMEOUT_SECONDS=65        # Combined fast+long pass time budget per file
THIRD_PASS_TIMEOUT_SECONDS=195      # Max budget for third-pass retry
GLOBAL_DOC_TIMEOUT_SECONDS=150      # Hard cap on total processing time per file
LARGE_FILE_THRESHOLD_BYTES=1000000  # Files over 1 MB sorted to end of queue (1 MB)
FASTLANE_IMAGE_ONLY_BUDGET_SECONDS=16.0           # Fast-lane OCR budget for image-only docs
FASTLANE_IMAGE_ONLY_HARD_DOC_BUDGET_SECONDS=16.0  # Hard limit for fast-lane image docs
ROTATION_PROBE_CERTAIN_MARGIN=240   # Score margin to call rotation CERTAIN vs LIKELY
MAX_CONTEXT_RESCUE_MS=35000         # Max time (ms) for context/table rescue passes
POLL_SECONDS=2                      # Watchdog polling interval
HEARTBEAT_SECONDS=10                # Heartbeat log interval
EXCEL_REFRESH_SECONDS=30            # How often the UI refreshes Excel counts


# -------------------------------------------------------------
# EDM DUPLICATE-CHECK TUNING                     ← OPTIONAL
# -------------------------------------------------------------

# Minimum rapidfuzz score to flag a page as a TEXT match (0-100).
# Scores 60-84 route to CLEAN-UNCHECKED (human review only, no auto-reject).
TEXT_SIMILARITY_THRESHOLD=60

# Minimum score for a TEXT match to count as STRONG evidence (like pHash).
# Scores >= this trigger routing decisions (REJECTED / SPLIT / NEEDS-REVIEW).
TEXT_STRONG_THRESHOLD=85

# Max EDM pages checked with OCR per incoming page
PAGE_OCR_LIMIT=8

# Perceptual hash Hamming distance — pages with diff <= this are pHash duplicates
PHASH_THRESHOLD=10

# --- Advanced EDM thresholds (uncomment to override defaults) ---

# Max pages compared via OCR per incoming page (default 10)
# EDM_OCR_COMPARE_LIMIT=10

# Threshold reject: reject whole file if STRONG dup pages > this AND ratio >= below (default 5)
# EDM_REJECT_IF_DUP_PAGES_OVER=5

# Threshold reject: minimum dup ratio required alongside page count above (default 0.70 = 70%)
# EDM_REJECT_IF_DUP_RATIO=0.70

# How many PROCESSED files to check simultaneously (default 3)
# EDM_WORKER_THREADS=3

# Seconds to wait for a new file to settle before processing (default 1).
# Raise to 3 if files arrive via a slow network share.
# EDM_FILE_SETTLE_SECONDS=1


# -------------------------------------------------------------
# BATCH BUILDER                                  ← OPTIONAL
# -------------------------------------------------------------

MAX_PAGES_PER_BATCH=48      # Maximum pages per print batch PDF
COVER_PAGE_SIZE=LETTER      # Cover page paper size: LETTER or A4


# -------------------------------------------------------------
# TIFF CONVERTER                                 ← OPTIONAL
# -------------------------------------------------------------

TIFF_DPI=200                # Output TIFF resolution
TIFF_COMPRESSION=tiff_lzw  # Compression: tiff_lzw | tiff_deflate | none
TIFF_GRAYSCALE=true         # Convert to grayscale (smaller files)
TIFF_SKIP_IF_EXISTS=true    # Skip conversion if TIFF already exists


# -------------------------------------------------------------
# AUTO MODE / BATCHING                           ← OPTIONAL
# -------------------------------------------------------------

# Minimum CLEAN batch count before auto-batch triggers (default 2)
# MIN_CLEAN_BATCHES_FOR_AUTO=2

# Force a batch when oldest CLEAN file has waited this long in seconds (default 1800 = 30 min)
# AUTO_FORCE_BATCH_AGE_SECONDS=1800

# Build separate High/Medium/Low confidence tier PDFs (default false)
# ENABLE_TIER_BATCHING=false

# Set to false to retire the legacy tracker once pipeline_audit.xlsx is confirmed stable
# WRITE_LEGACY_TRACKER=true


# -------------------------------------------------------------
# ADVANCED                        ← leave as defaults unless told otherwise
# -------------------------------------------------------------

# AUTO_INTERVAL_SEC=10                  # Auto-mode polling interval (seconds)
# INBOX_EMPTY_STABLE_SECONDS=8         # Seconds inbox must be empty before stable
# INBOX_EMPTY_MAX_WAIT=1800            # Max wait for inbox to clear (seconds)
# PROCESSED_EMPTY_STABLE_SECONDS=5     # Seconds PROCESSED must be empty before stable
# PROCESSED_EMPTY_MAX_WAIT=600         # Max wait for PROCESSED to clear (seconds)
# FILE_SETTLE_SECONDS=3                # Hotfolder file settle wait (seconds)
# MIN_EMBEDDED_TEXT_LENGTH=25          # Min chars to trust a PDF text layer
