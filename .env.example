# =============================================================
# AWB Pipeline — .env template
# Copy this file to .env and fill in your values.
# The installers (Install_Mac.command / Install_Windows.bat)
# set PIPELINE_BASE_DIR and TESSERACT_PATH automatically.
# =============================================================


# -------------------------------------------------------------
# PATHS  *** REQUIRED ***
# Set automatically by the installer. Update if you move the folder.
# -------------------------------------------------------------

PIPELINE_BASE_DIR=
TESSERACT_PATH=


# -------------------------------------------------------------
# FEDEX EDM API  *** REQUIRED ***
# Paste your raw token below (no "Bearer" prefix).
# Token file: data/token.txt also works and takes priority.
# -------------------------------------------------------------

EDM_TOKEN=paste_your_token_here
EDM_OPERATING_COMPANY=FXE
EDM_BASE_URL=https://shipment-portal-service-g.prod.cloud.fedex.com
EDM_PORTAL_URL=https://shipment-portal-g.prod.cloud.fedex.com
# Default startup mode (UI button can toggle at runtime and persist it)
ENABLE_EDM_FALLBACK=false


# -------------------------------------------------------------
# OCR / AWB MATCHING
# -------------------------------------------------------------

OCR_DPI_MAIN=320
OCR_DPI_STRONG=420
ENABLE_ROTATION_LAST_RESORT=true
LONG_PASS_TIMEOUT_SECONDS=45
POLL_SECONDS=2
HEARTBEAT_SECONDS=10
EXCEL_REFRESH_SECONDS=30

# Rotation probe tuning
# ROTATION_PROBE_CERTAIN_MARGIN=300
# ROTATION_PROBE_LIKELY_MARGIN=120
# ROTATION_PROBE_MIN_FLIP_MARGIN=80
# ROTATION_PROBE_DIGIT_CLEAR_MARGIN=24

# Fast-lane budgets (seconds)
# FASTLANE_IMAGE_ONLY_BUDGET_SECONDS=16.0
# FASTLANE_IMAGE_ONLY_HARD_DOC_BUDGET_SECONDS=16.0

# Context/rescue pass budget (ms)
# MAX_CONTEXT_RESCUE_MS=60000

# Fast-lane feature flags (all default to true)
# FASTLANE_MICRO_PROBE_ENABLED=true
# FASTLANE_SINGLE_ROTATED_PASS_ENABLED=true
# FASTLANE_EARLY_HINT_ROTATED_PROBE_ENABLED=true
# FASTLANE_STAGE3_EARLY_ROTATED_PASS_ENABLED=true
# FASTLANE_EARLY_ROTATION_ROUTE_ENABLED=true
# FASTLANE_QUICK_ROTATED_PSM6_ENABLED=true
# FASTLANE_ROTATED_TOL1_ENABLED=true
# FASTLANE_CERTAIN_ROTATION_RESCUE_LITE_ENABLED=true


# -------------------------------------------------------------
# EDM DUPLICATE-CHECK TUNING
# -------------------------------------------------------------

TEXT_SIMILARITY_THRESHOLD=85
PAGE_OCR_LIMIT=8
PHASH_THRESHOLD=10
EDM_OCR_WORKERS=2
EDM_OCR_PARALLEL_MIN_TASKS=4

# EDM page scan windows (Gate 2 / Tier 2)
# EDM_TIER1_INCOMING_PAGES=3
# EDM_TIER1_EDM_PAGE_LIMIT=5
# EDM_TIER2_EDM_PAGE_LIMIT=10

# EDM rejection thresholds
# EDM_REJECT_IF_DUP_PAGES_OVER=5
# EDM_REJECT_IF_DUP_RATIO=0.70
# EDM_OCR_COMPARE_LIMIT=10
# EDM_TEXT_LAYER_MIN_CHARS=30


# -------------------------------------------------------------
# BATCH BUILDER
# -------------------------------------------------------------

MAX_PAGES_PER_BATCH=48
COVER_PAGE_SIZE=LETTER


# -------------------------------------------------------------
# TIFF CONVERTER
# -------------------------------------------------------------

TIFF_DPI=200
TIFF_COMPRESSION=tiff_lzw
TIFF_GRAYSCALE=true
TIFF_SKIP_IF_EXISTS=true


# -------------------------------------------------------------
# AUTO MODE
# -------------------------------------------------------------

# Minimum batches required before auto-batch triggers (default 2)
# MIN_CLEAN_BATCHES_FOR_AUTO=2

# Set to true to build separate tier PDFs (High/Medium/Low confidence)
# ENABLE_TIER_BATCHING=false

# Set to false once pipeline_audit.xlsx is confirmed stable
# WRITE_LEGACY_TRACKER=true


# -------------------------------------------------------------
# ADVANCED (leave as defaults unless advised)
# -------------------------------------------------------------

# AUTO_INTERVAL_SEC=10
# INBOX_EMPTY_STABLE_SECONDS=8
# INBOX_EMPTY_MAX_WAIT=1800
# PROCESSED_EMPTY_STABLE_SECONDS=5
# PROCESSED_EMPTY_MAX_WAIT=600
# FILE_SETTLE_SECONDS=3
# MIN_EMBEDDED_TEXT_LENGTH=25
