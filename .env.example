# =============================================================
# AWB Pipeline V3 — Environment Configuration
# =============================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every line marked  ← REQUIRED
#   3. Lines marked  ← OPTIONAL  have working defaults
#   4. EDM token: paste raw token into  data/token.txt  (no "Bearer" prefix)
#   5. Commented-out lines are disabled — uncomment only to override defaults
# =============================================================


# -------------------------------------------------------------
# PATHS                                          ← REQUIRED
# -------------------------------------------------------------

# Full absolute path to project root (contains pdf_organizer/ and data/).
#   Mac:     /Users/yourname/Desktop/ScavGajjar21
#   Windows: C:/Users/yourname/Desktop/ScavGajjar21
PIPELINE_BASE_DIR=                                          # ← REQUIRED

# Full path to Tesseract binary.
#   Mac (Homebrew):  /opt/homebrew/bin/tesseract
#   Mac (Intel):     /usr/local/bin/tesseract
#   Windows:         C:/Program Files/Tesseract-OCR/tesseract.exe
#   Linux:           /usr/bin/tesseract
TESSERACT_PATH=                                             # ← REQUIRED


# -------------------------------------------------------------
# FEDEX EDM API                                  ← REQUIRED
# -------------------------------------------------------------
# Ask your FedEx EDM admin for these values.
# Token: paste raw Bearer token into data/token.txt — do NOT put it here.

# FedEx operating company code (e.g. FXE, FXSP, FXNL — ask FedEx)
EDM_OPERATING_COMPANY=                                      # ← REQUIRED

# FedEx EDM API base URL (provided by FedEx)
EDM_BASE_URL=                                               # ← REQUIRED

# FedEx EDM portal URL (used for request headers)
EDM_PORTAL_URL=                                             # ← REQUIRED


# -------------------------------------------------------------
# OCR / AWB MATCHING                             ← OPTIONAL
# -------------------------------------------------------------

OCR_DPI_MAIN=320                    # DPI for first OCR pass
OCR_DPI_STRONG=420                  # DPI for deep OCR pass
ENABLE_ROTATION_LAST_RESORT=true    # Try all rotation angles as last resort
LONG_PASS_TIMEOUT_SECONDS=65        # Combined fast+long pass budget per file (seconds)
THIRD_PASS_TIMEOUT_SECONDS=195      # Max budget for third-pass retry (seconds)
GLOBAL_DOC_TIMEOUT_SECONDS=150      # Hard cap on total processing time per file (seconds)
LARGE_FILE_THRESHOLD_BYTES=1000000  # Files over this size sorted to end of queue (bytes)
FASTLANE_IMAGE_ONLY_BUDGET_SECONDS=16.0           # Fast-lane OCR budget for image-only docs
FASTLANE_IMAGE_ONLY_HARD_DOC_BUDGET_SECONDS=16.0  # Hard limit for fast-lane image docs
ROTATION_PROBE_CERTAIN_MARGIN=240   # Probe score margin to call rotation CERTAIN vs LIKELY
MAX_CONTEXT_RESCUE_MS=35000         # Max time for context/table rescue passes (ms)
POLL_SECONDS=2
HEARTBEAT_SECONDS=10
EXCEL_REFRESH_SECONDS=30

# Rotation probe fine-tuning (uncomment to override)
# ROTATION_PROBE_LIKELY_MARGIN=120
# ROTATION_PROBE_MIN_FLIP_MARGIN=80
# ROTATION_PROBE_DIGIT_CLEAR_MARGIN=24

# Fast-lane feature flags (all default true — uncomment to disable)
# FASTLANE_MICRO_PROBE_ENABLED=true
# FASTLANE_SINGLE_ROTATED_PASS_ENABLED=true
# FASTLANE_EARLY_HINT_ROTATED_PROBE_ENABLED=true
# FASTLANE_STAGE3_EARLY_ROTATED_PASS_ENABLED=true
# FASTLANE_EARLY_ROTATION_ROUTE_ENABLED=true
# FASTLANE_QUICK_ROTATED_PSM6_ENABLED=true
# FASTLANE_ROTATED_TOL1_ENABLED=true
# FASTLANE_CERTAIN_ROTATION_RESCUE_LITE_ENABLED=true


# -------------------------------------------------------------
# EDM DUPLICATE-CHECK TUNING                     ← OPTIONAL
# -------------------------------------------------------------

# Minimum rapidfuzz score to flag a TEXT match (0-100).
# Scores 60-84 → CLEAN-UNCHECKED (human review only, no auto-reject).
TEXT_SIMILARITY_THRESHOLD=60

# Minimum score for TEXT match to count as STRONG evidence (triggers REJECTED/SPLIT).
TEXT_STRONG_THRESHOLD=85

# Max EDM pages checked with OCR per incoming page
PAGE_OCR_LIMIT=8

# Perceptual hash Hamming distance — diff <= this = pHash duplicate
PHASH_THRESHOLD=10

# Parallel OCR sub-threads per file worker (default 2)
EDM_OCR_WORKERS=2
EDM_OCR_PARALLEL_MIN_TASKS=4

# EDM page scan windows
# EDM_TIER1_INCOMING_PAGES=3
# EDM_TIER1_EDM_PAGE_LIMIT=5
# EDM_TIER2_EDM_PAGE_LIMIT=10

# EDM rejection thresholds
# EDM_REJECT_IF_DUP_PAGES_OVER=5
# EDM_REJECT_IF_DUP_RATIO=0.70
# EDM_OCR_COMPARE_LIMIT=10
# EDM_TEXT_LAYER_MIN_CHARS=30

# Parallel file workers (default 3)
# EDM_WORKER_THREADS=3

# File settle wait before processing (default 1s; raise to 3 on slow network shares)
# EDM_FILE_SETTLE_SECONDS=1


# -------------------------------------------------------------
# BATCH BUILDER                                  ← OPTIONAL
# -------------------------------------------------------------

MAX_PAGES_PER_BATCH=48      # Max pages per print batch PDF
COVER_PAGE_SIZE=LETTER      # Cover page size: LETTER or A4


# -------------------------------------------------------------
# TIFF CONVERTER                                 ← OPTIONAL
# -------------------------------------------------------------

TIFF_DPI=200
TIFF_COMPRESSION=tiff_lzw  # Options: tiff_lzw | tiff_deflate | none
TIFF_GRAYSCALE=true
TIFF_SKIP_IF_EXISTS=true


# -------------------------------------------------------------
# AUTO MODE / BATCHING                           ← OPTIONAL
# -------------------------------------------------------------

# Minimum CLEAN batches before auto-batch triggers (default 2)
# MIN_CLEAN_BATCHES_FOR_AUTO=2

# Force batch when oldest CLEAN file has waited this long (default 1800s = 30 min)
# AUTO_FORCE_BATCH_AGE_SECONDS=1800

# Build separate High/Medium/Low confidence tier PDFs (default false)
# ENABLE_TIER_BATCHING=false

# Retire legacy tracker once pipeline_audit.xlsx is confirmed stable
# WRITE_LEGACY_TRACKER=true


# -------------------------------------------------------------
# ADVANCED                        ← leave as defaults unless advised
# -------------------------------------------------------------

# AUTO_INTERVAL_SEC=10
# INBOX_EMPTY_STABLE_SECONDS=8
# INBOX_EMPTY_MAX_WAIT=1800
# PROCESSED_EMPTY_STABLE_SECONDS=5
# PROCESSED_EMPTY_MAX_WAIT=600
# FILE_SETTLE_SECONDS=3
# MIN_EMBEDDED_TEXT_LENGTH=25
